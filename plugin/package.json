{
  "name": "@alexjorgef/gatsby-source-github",
  "version": "0.0.2",
  "description": "Gatsby source plugin for GitHub",
  "main": "dist/gatsby-node.js",
  "source": "src/gatsby-node.ts",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/*",
    "gatsby-node.js"
  ],
  "repository": "https://github.com/alexjorgef/gatsby-source-github.git",
  "keywords": [
    "github",
    "gatsby",
    "gatsby-plugin",
    "gatsby-source-plugin",
    "gatsby-github",
    "gatsby-source-github"
  ],
  "author": "Alexandre Ferreira <contact@alexjorgef.com>",
  "license": "MIT",
  "dependencies": {
    "@alexjorgef/mixjar": "^0.1.3",
    "graphql-request": "~7.4.0",
    "lodash": "4.17.21"
  },
  "bugs": {
    "url": "https://github.com/alexjorgef/gatsby-source-github/issues"
  },
  "homepage": "https://github.com/alexjorgef/gatsby-source-github#readme",
  "devDependencies": {
    "@parcel/packager-ts": "^2.9.3",
    "@parcel/transformer-typescript-types": "^2.9.3",
    "del-cli": "^5.0.1",
    "gatsby": "^5.12.1",
    "gatsby-plugin-utils": "^4.12.0",
    "parcel": "^2.9.3"
  },
  "peerDependencies": {
    "gatsby": "^5.0.0-next.0"
  },
  "scripts": {
    "watch": "parcel watch",
    "build": "parcel build --no-source-maps",
    "prepare": "npm run clean && npm run build",
    "clean": "del-cli dist/*"
  },
  "packageManager": "yarn@4.14.1"
}
